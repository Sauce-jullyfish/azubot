# ============================================================
# azubot minimal environment
# ============================================================

AZUBOT_ENV=development
TZ=Asia/Taipei

FORCE_COLOR=1
PYTHONUNBUFFERED=1


# ============================================================
# public routing
# ============================================================

PUBLIC_BASE_URL=https://azubot.xyz
API_V1_PREFIX=/api/v1
API_PUBLIC_BASE_URL=https://azubot.xyz/api/v1


# ============================================================
# local dev ports
# ============================================================

WEB_HOST=0.0.0.0
WEB_PORT=5173

API_HOST=127.0.0.1
API_PORT=8000


# ============================================================
# frontend
# ============================================================

VITE_API_BASE_URL=/api/v1


# ============================================================
# PostgreSQL
# DATABASE_URL / BOT_DATABASE_URL 由 pydantic-settings 組合
# ============================================================

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=azubot
POSTGRES_PASSWORD=change_me_dev_password
POSTGRES_DB=azubot


# ============================================================
# Cloudflare Tunnel
# ============================================================

CLOUDFLARED_TUNNEL_TOKEN=


# ============================================================
# Discord Bot
# ============================================================

DISCORD_TOKEN=
BOT_API_BASE_URL=http://localhost:8000/api/v1


# ============================================================
# Twitch
# FastAPI 使用 client_id + client_secret 取得 app access token
# ============================================================

TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_WEBHOOK_SECRET=


# ============================================================
# YouTube Data API v3
# Public data request 使用 API key
# ============================================================

YOUTUBE_API_KEY=